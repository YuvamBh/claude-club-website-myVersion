// Prisma schema for HackASU platform
// Better Auth manages: user, session, account, verification (DO NOT TOUCH those tables)
// This schema manages all hackathon-specific tables prefixed with hackathon_

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum HackathonRole {
  PARTICIPANT
  ADMIN
  JUDGE
  ORGANIZER
  MENTOR
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  WAITLISTED
  REJECTED
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  SHORTLISTED
  WINNER
  DISQUALIFIED
}

enum TeamRole {
  CAPTAIN
  MEMBER
}

// ─── Core Hackathon User (extends Better Auth user) ──────────────────────────

model HackathonUser {
  id        String        @id @default(cuid())
  userId    String        @unique // References Better Auth user.id
  email     String        @unique
  name      String
  role      HackathonRole @default(PARTICIPANT)

  profile         ParticipantProfile?
  application     Application?
  teamMemberships TeamMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hackathon_users")
}

// ─── Participant Profile (additional profile data) ────────────────────────────

model ParticipantProfile {
  id     String        @id @default(cuid())
  userId String        @unique
  user   HackathonUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  university String?
  major      String?
  year       String? // freshman, sophomore, junior, senior, graduate
  phone      String?
  linkedin   String?
  github     String?
  website    String?
  bio        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hackathon_participant_profiles")
}

// ─── Hackathon (the event itself) ────────────────────────────────────────────

model Hackathon {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  tagline     String?
  description String?
  bannerUrl   String?

  startDate DateTime
  endDate   DateTime

  applicationDeadline DateTime?
  submissionDeadline  DateTime?

  isActive    Boolean @default(false)
  isPublished Boolean @default(false)

  tracks          Track[]
  rules           Rule[]
  faqs            FAQ[]
  announcements   Announcement[]
  judgingCriteria JudgingCriteria[]
  applications    Application[]
  teams           Team[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hackathons")
}

// ─── Track ───────────────────────────────────────────────────────────────────

model Track {
  id          String    @id @default(cuid())
  hackathonId String
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id])

  name        String
  description String?
  icon        String?
  color       String?

  teams Team[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hackathon_tracks")
}

// ─── Rules ───────────────────────────────────────────────────────────────────

model Rule {
  id          String    @id @default(cuid())
  hackathonId String
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id])

  title   String
  content String
  order   Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hackathon_rules")
}

// ─── FAQ ─────────────────────────────────────────────────────────────────────

model FAQ {
  id          String    @id @default(cuid())
  hackathonId String
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id])

  question String
  answer   String
  order    Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hackathon_faqs")
}

// ─── Announcement ────────────────────────────────────────────────────────────

model Announcement {
  id          String    @id @default(cuid())
  hackathonId String
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id])

  title       String
  content     String
  isPinned    Boolean   @default(false)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hackathon_announcements")
}

// ─── Judging Criteria ────────────────────────────────────────────────────────

model JudgingCriteria {
  id          String    @id @default(cuid())
  hackathonId String
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id])

  name        String
  description String?
  weight      Int    @default(1)
  maxScore    Int    @default(10)
  order       Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hackathon_judging_criteria")
}

// ─── Application ─────────────────────────────────────────────────────────────

model Application {
  id          String            @id @default(cuid())
  userId      String            @unique
  user        HackathonUser     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hackathonId String
  hackathon   Hackathon         @relation(fields: [hackathonId], references: [id])
  status      ApplicationStatus @default(DRAFT)

  // Personal
  university String?
  major      String?
  year       String?

  // Experience
  experienceLevel String? // beginner, intermediate, advanced
  desiredTracks   String[] // array of track names/ids
  priorExperience String?
  whyJoin         String?

  // Links
  linkedinUrl String?
  githubUrl   String?
  resumeUrl   String? // Vercel Blob / S3 URL

  // Operational
  dietaryNeeds       String?
  accessibilityNeeds String?

  // Agreement
  agreedToRules Boolean   @default(false)
  agreedAt      DateTime?

  // Admin
  adminNotes String?
  reviewedAt DateTime?
  reviewedBy String? // HackathonUser.id

  submittedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("hackathon_applications")
}

// ─── Team ────────────────────────────────────────────────────────────────────

model Team {
  id          String    @id @default(cuid())
  hackathonId String
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id])
  trackId     String?
  track       Track?    @relation(fields: [trackId], references: [id])

  name       String
  inviteCode String @unique @default(cuid())
  maxSize    Int    @default(4)
  isLocked   Boolean @default(false) // locked after submission deadline

  members    TeamMember[]
  submission Submission?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hackathon_teams")
}

// ─── Team Member ─────────────────────────────────────────────────────────────

model TeamMember {
  id     String        @id @default(cuid())
  teamId String
  team   Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId String
  user   HackathonUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())

  @@unique([teamId, userId])
  @@map("hackathon_team_members")
}

// ─── Submission ──────────────────────────────────────────────────────────────

model Submission {
  id          String           @id @default(cuid())
  teamId      String           @unique
  team        Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  hackathonId String
  status      SubmissionStatus @default(DRAFT)

  // Project info
  projectName      String?
  tagline          String?
  trackId          String?
  shortDescription String?
  longDescription  String?
  problemStatement String?
  solutionOverview String?
  techStack        String[]

  // Links
  githubUrl       String?
  demoUrl         String?
  videoUrl        String?
  presentationUrl String?
  deploymentUrl   String?
  designUrl       String?
  additionalNotes String?

  // Assets
  assets SubmissionAsset[]

  // Compliance
  agreedToRules Boolean   @default(false)
  agreedAt      DateTime?

  // Admin
  adminNotes String?
  reviewedAt DateTime?
  reviewedBy String? // HackathonUser.id

  submittedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("hackathon_submissions")
}

// ─── Submission Asset ────────────────────────────────────────────────────────

model SubmissionAsset {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  name      String
  url       String
  assetType String // pdf, image, zip, link, etc.
  sizeBytes Int?

  createdAt DateTime @default(now())

  @@map("hackathon_submission_assets")
}

// ─── Email Intake Record (from Gmail/Google Sheets pipeline) ─────────────────

model EmailIntakeRecord {
  id String @id @default(cuid())

  // Gmail metadata
  gmailMessageId String   @unique
  gmailThreadId  String
  sender         String
  subject        String
  receivedAt     DateTime

  // Extracted content
  bodyExcerpt       String?
  extractedLinks    String[]
  teamIdentifier    String?
  projectIdentifier String?
  attachmentNames   String[]

  // Processing state
  processingStatus String    @default("pending") // pending | processed | imported | error
  processedAt      DateTime?
  importedAt       DateTime?
  importError      String?

  // Resolved references
  submissionId String?
  teamId       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hackathon_email_intake")
}

// ─── Activity Log ────────────────────────────────────────────────────────────

model ActivityLog {
  id String @id @default(cuid())

  userId     String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?

  createdAt DateTime @default(now())

  @@map("hackathon_activity_log")
}
